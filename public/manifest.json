{
  "manifest_version": 3,
  "name": "Chromo Design",
  "version": "0.2.0",
  "description": "Visual webpage editor — edit any page like Figma",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "tabs", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
